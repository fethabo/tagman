{
  "name": "@fethabo/tagman",
  "version": "1.3.7",
  "dependencies": {
    "@clack/core": "^1.1.0",
    "@clack/prompts": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "commander": "^14.0.3",
    "conventional-commits-parser": "^6.3.0",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "simple-git": "^3.33.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/conventional-commits-parser": "^5.0.2",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "description": "Herramienta CLI interactiva en TypeScript para la gestion de versionado y tagging granular en monorepos (pnpm workspaces).",
  "author": "fethabo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fethabo/tagman.git"
  },
  "bugs": {
    "url": "https://github.com/fethabo/tagman/issues"
  },
  "homepage": "https://github.com/fethabo/tagman#readme",
  "keywords": [
    "git",
    "tag",
    "monorepo",
    "versioning",
    "pnpm",
    "cli",
    "automation",
    "changelog"
  ],
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "tagman": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "module": ".dist/index.mjs",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node bin/tagman.js"
  }
}
